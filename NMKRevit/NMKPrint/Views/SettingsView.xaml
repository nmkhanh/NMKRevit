<UserControl
  x:Class="NMKRevit.NMKPrint.Views.SettingsView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <SolidColorBrush x:Key="SettingsAccentBrush" Color="#FF5A00" />
    <Style x:Key="SettingsTabItemStyle" TargetType="TabItem">
      <Setter Property="Width" Value="84" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Grid Background="Transparent">
              <ContentPresenter
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                ContentSource="Header" />
              <Border
                x:Name="ActiveLine"
                Height="3"
                VerticalAlignment="Bottom"
                Background="Transparent" />
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="ActiveLine" Property="Background" Value="{StaticResource SettingsAccentBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>
  <TabControl
    Background="White"
    BorderBrush="#BFD3E8"
    BorderThickness="0"
    ItemContainerStyle="{StaticResource SettingsTabItemStyle}">
    <TabItem Header="PDF">
      <Grid Margin="6,18,6,6">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="600" />
          <ColumnDefinition Width="1.05*" />
          <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox Header="Paper Placement" Margin="0,0,10,10">
          <Grid Margin="4,6,4,4">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <RadioButton Content="Center" IsChecked="{Binding Settings.PaperPlacementCenter}" Height="24" VerticalContentAlignment="Center" />
            <RadioButton Grid.Row="1" Content="Offset from corner" IsChecked="{Binding Settings.PaperPlacementOffsetFromCorner}" Height="24" VerticalContentAlignment="Center" />
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="30,2,0,0" Height="24">
              <RadioButton Content="No Margin" IsChecked="{Binding Settings.OffsetNoMargin}" Margin="0,0,14,0" />
              <RadioButton Content="Printer limit" IsChecked="{Binding Settings.OffsetPrinterLimit}" Margin="0,0,14,0" />
              <RadioButton Content="User Defined" IsChecked="{Binding Settings.OffsetUserDefined}" />
            </StackPanel>
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0">
              <TextBlock Text="X (mm)" Margin="20,5,6,0" />
              <TextBox Width="100" Text="{Binding Settings.OffsetX}" />
              <TextBlock Text="Y (mm)" Margin="10,5,6,0" />
              <TextBox Width="100" Text="{Binding Settings.OffsetY}" />
            </StackPanel>
          </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="Zoom" Margin="0,0,10,10">
          <StackPanel Margin="8">
            <RadioButton Content="Fit to Page" IsChecked="{Binding Settings.ZoomFitToPage}" />
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
              <RadioButton Content="Zoom" IsChecked="{Binding Settings.ZoomCustom}" VerticalAlignment="Center" />
              <TextBox Width="90" Text="{Binding Settings.ZoomPercentage}" Margin="12,0,6,0" />
              <TextBlock Text="% Size" VerticalAlignment="Center" />
            </StackPanel>
          </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Printer" Margin="0,0,10,0">
          <Grid Margin="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="72" />
              <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Printer" VerticalAlignment="Center" />
            <ComboBox Grid.Column="1" Height="30" ItemsSource="{Binding Printers}" SelectedItem="{Binding Settings.PrinterName}" />
          </Grid>
        </GroupBox>

        <GroupBox Grid.Column="1" Header="Hidden Line Views" Margin="0,0,10,10">
          <StackPanel Margin="8">
            <TextBlock Text="Remove Lines Using" Margin="0,0,0,8" />
            <RadioButton Content="Vector Processing" IsChecked="{Binding Settings.VectorProcessing}" />
            <RadioButton Content="Raster Processing" IsChecked="{Binding Settings.RasterProcessing}" Margin="0,8,0,0" />
          </StackPanel>
        </GroupBox>

        <GroupBox Grid.Column="1" Grid.Row="1" Header="Appearance" Margin="0,0,10,10">
          <Grid Margin="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="110" />
              <ColumnDefinition Width="170" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="Raster Quality" VerticalAlignment="Center" />
            <ComboBox Grid.Column="1" Height="30" SelectedValuePath="Content" SelectedValue="{Binding Settings.SelectedRasterQuality}">
              <ComboBoxItem Content="Low" />
              <ComboBoxItem Content="Medium" />
              <ComboBoxItem Content="High" />
              <ComboBoxItem Content="Presentation" />
            </ComboBox>
            <TextBlock Grid.Row="1" Text="Colors" Margin="0,10,0,0" VerticalAlignment="Center" />
            <ComboBox Grid.Row="1" Grid.Column="1" Height="30" Margin="0,10,0,0" SelectedValuePath="Content" SelectedValue="{Binding Settings.SelectedColor}">
              <ComboBoxItem Content="Black Lines" />
              <ComboBoxItem Content="Gray Scale" />
              <ComboBoxItem Content="Color" />
            </ComboBox>
          </Grid>
        </GroupBox>

        <GroupBox Grid.Column="2" Header="Options">
          <StackPanel Margin="8">
            <CheckBox Content="View links in blue (Color prints only)" IsChecked="{Binding Settings.ViewLinksInBlue}" Margin="0,0,0,8" />
            <CheckBox Content="Hide ref/work planes" IsChecked="{Binding Settings.HideRefWorkPlanes}" Margin="0,0,0,8" />
            <CheckBox Content="Hide unreferenced view tags" IsChecked="{Binding Settings.HideUnreferencedViewTags}" Margin="0,0,0,8" />
            <CheckBox Content="Hide scope boxes" IsChecked="{Binding Settings.HideScopeBoxes}" Margin="0,0,0,8" />
            <CheckBox Content="Hide crop boundaries" IsChecked="{Binding Settings.HideCropBoundaries}" Margin="0,0,0,8" />
            <CheckBox Content="Replace halftone with thin lines" IsChecked="{Binding Settings.ReplaceHalftoneWithThinLines}" Margin="0,0,0,8" />
            <CheckBox Content="Region edges mask coincident lines" IsChecked="{Binding Settings.RegionEdgesMaskCoincidentLines}" />
          </StackPanel>
        </GroupBox>
      </Grid>
    </TabItem>

    <TabItem Header="DWG">
      <Grid Margin="10">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <GroupBox Header="Select Export Setup">
          <Grid Margin="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="90" />
              <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Name" VerticalAlignment="Center" />
            <ComboBox Grid.Column="1" Height="30" ItemsSource="{Binding DwgExportSetups}" SelectedItem="{Binding Settings.DwgExportSetup}" />
          </Grid>
        </GroupBox>
        <CheckBox Grid.Row="1" Margin="0,18,0,0" Content="Export views on sheets and links as external references" IsChecked="{Binding Settings.ExportViewsAsExternalReferences}" />
      </Grid>
    </TabItem>
  </TabControl>
</UserControl>
