{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "RebarFoundation.schema.json",
  "title": "AI image/data to Revit rebar group",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "units", "distribution", "bars"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "units": { "const": "mm" },
    "name": { "type": "string" },
    "distribution": { "$ref": "#/$defs/distribution" },
    "bars": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/bar" }
    }
  },
  "$defs": {
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "offsetsMm": {
          "type": ["array", "null"],
          "items": { "type": "number", "minimum": 0 }
        },
        "spacingsMm": {
          "type": ["array", "null"],
          "items": { "type": "number", "exclusiveMinimum": 0 }
        },
        "count": { "type": ["integer", "null"], "minimum": 1 },
        "spacingMm": { "type": ["number", "null"], "exclusiveMinimum": 0 }
      }
    },
    "bar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "diameterMm", "shape"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "mark": { "type": "string" },
        "enabled": { "type": "boolean" },
        "diameterMm": { "type": "number", "exclusiveMinimum": 0 },
        "typeName": { "type": ["string", "null"] },
        "side": { "enum": ["auto", "left", "right", null] },
        "distribution": { "oneOf": [{ "$ref": "#/$defs/distribution" }, { "type": "null" }] },
        "shape": { "$ref": "#/$defs/shape" }
      }
    },
    "shape": {
      "type": "object",
      "additionalProperties": false,
      "required": ["points"],
      "properties": {
        "points": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/point" }
        }
      }
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["xMm", "zMm"],
      "properties": {
        "xMm": { "type": "number" },
        "zMm": { "type": "number" }
      }
    }
  }
}
